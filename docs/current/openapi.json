            "default": false
          },
          "confirm_long_web_video_asr": {
            "type": "boolean",
            "title": "Confirm Long Web Video Asr",
            "description": "用户已确认对超长网页视频（超过 V16_WEB_VIDEO_ASR_FALLBACK_MAX_SEC）走 ASR",
