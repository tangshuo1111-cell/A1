            "default": false
          },
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File",
            "description": "待 prepare 的文件（如 .txt/.md/.docx/.pdf/.xlsx，≤ 10 MB）"
          }
        },
        "type": "object",
        "required": [
          "message",
          "file"
        ],
        "title": "Body_post_chat_agno_upload_chat_agno_upload_post"
      },
