.pytest_cache/
**/.pytest_cache/
.coverage
coverage.xml
htmlcov/
.ruff_cache/
**/.ruff_cache/
__pycache__/
**/__pycache__/
*.pyc

# IDE / OS
.idea/
.vscode/*
!.vscode/settings.json
*.swp
Thumbs.db
Desktop.ini

