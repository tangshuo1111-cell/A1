# _local: 所有运行产物（日志/缓存/上传/输出/数据库）
_local/

# 审查包副本（勿与主树混用）
_review_package/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.ruff_cache/
.pytype/
*.log
logs/

# 本地密钥与覆盖（示例文件 .env.example 需提交）
.env
**/.env
.env.local
.env.*.local
env..txt
**/env..txt
web/.env.local
frontend/.env.local

# 本地数据（bootstrap / 运行生成；勿提交真实库）
# V16-r5b 安全清理：扩展为递归匹配，覆盖 08_数据与样例/data/ 与任意层级 data/
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-wal
data/*.sqlite-shm
data/*.db
**/data/*.sqlite
**/data/*.sqlite-journal
**/data/*.sqlite-wal
**/data/*.sqlite-shm
**/data/*.sqlite*
**/data/*.db
# 临时清理 / 调试 sqlite
_tmp_clean_debug.sqlite
**/_tmp_*.sqlite
**/_tmp_*.sqlite-*

# 本地 cookies（含登录态明文；用户授权后本地使用，勿入仓）
**/data/cookies/*
**/cookies/*.txt
**/video_cookies.txt

# 项目代码归档/快照（如 130MB zip）
*.zip
项目代码.zip
**/项目代码*.zip

