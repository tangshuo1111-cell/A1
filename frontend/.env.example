# =============================================================================
# Next.js 前端（web/）环境变量
# 复制为 .env.local：  Copy-Item .env.example .env.local
# 注意：仅 NEXT_PUBLIC_* 会暴露到浏览器，勿写后端密钥。
# =============================================================================

# 后端地址：供 next.config.ts 的 rewrites 使用（服务端读取，不暴露给浏览器）
BACKEND_URL=http://127.0.0.1:8000

# 若设置则浏览器直连该 URL（需后端 CORS_ORIGINS 包含前端 Origin）；留空则用同源 /api-proxy
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 可选：产品名（若后续 UI 读取）
# NEXT_PUBLIC_APP_NAME=Light MAQA

# 设为 1 时始终显示右侧调试轨；不设或设 0 则默认隐藏，由页面按钮展开
# NEXT_PUBLIC_SHOW_DEBUG_PANEL=1
