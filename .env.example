# =============================================================================
# Light MAQA — 环境变量模板（勿在此文件填入真实密钥）
# -----------------------------------------------------------------------------
# 使用：复制到项目根目录为 `.env`，或通过机密管理 / CI 注入同名变量。
#   PowerShell:  Copy-Item .env.example .env
# 说明：敏感 keys（LLM、云 OCR/ASR 等）仅放在本地 `.env` 或外部保管，勿提交仓库。
# =============================================================================

# --- A. 基础运行 ----------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
# 对外提供 API 时建议设置静态密钥：非空则除 /health /docs /openapi.json /redoc（及 Swagger 静态）外均需
# Authorization: Bearer <同上>
# API_BEARER_TOKEN=your-secret-token-here
# 运行态数据目录（默认 _local/data；上传 / cookies 等落盘；数据库在 PostgreSQL）
# DATA_DIR=_local/data
# 服务端仅使用 PostgreSQL：必填，与 docker-compose / CI 中账号一致（勿提交生产口令）
DATABASE_URL=postgresql://light_maqa:light_maqa_dev@127.0.0.1:5432/light_maqa

# --- B. LLM（OpenAI 兼容 API）----------------------------------------------------
# 留空 = no-key 模式：主路由可走规则；不调用 chat.completions
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
USE_LLM_ROUTER=1
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- C. Agent 模型覆盖（可选，共用 LLM_API_KEY）----------------------------------

# --- D. 检索 --------------------------------------------------------------------
# 默认统一口径：对业务方只暴露 auto 主路；keyword / semantic / hybrid 仅用于内部调试。
RETRIEVAL_MODE=auto
# 默认开启 embedding：auto 会优先尝试 hybrid；若 rag_embeddings 无数据则自动回退 keyword。
EMBEDDING_ENABLED=1
# 兼容旧变量名：仅控制 keyword 路径内是否启用轻量 TF-IDF 重排，不表示默认主路是 hybrid。
RAG_HYBRID=1
# 复杂题默认同步预算：30s。超过后应优先交付 partial、缩范围或转 async。
CHAT_SYNC_BUDGET_MS=30000
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- E~M. 其余开关与第三方（按需取消注释并填写）----------------------------------
# 前端 Next（须在 frontend/.env.local 配置）：与后端 Bearer 对齐时填入相同密钥
# NEXT_PUBLIC_API_BEARER_TOKEN=your-secret-token-here
